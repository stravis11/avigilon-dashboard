# Server Configuration
PORT=3001
NODE_ENV=development

# Avigilon ACC Configuration
# Default WEP port is 8443 (or 443 on production appliances)
ACC_SERVER_URL=https://localhost:8443
ACC_USERNAME=your_acc_username
ACC_PASSWORD=your_acc_password
ACC_USER_NONCE=your_user_nonce
ACC_USER_KEY=your_user_key
ACC_CLIENT_NAME=AvigilonWebApp

# Zabbix Configuration (SNMP hardware monitoring)
# Generate an API token in Zabbix: click your username → Profile → API tokens → Add
ZABBIX_URL=https://gtpd-zabbix.police.gatech.edu/zabbix/api_jsonrpc.php
ZABBIX_API_TOKEN=your_zabbix_api_token

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
